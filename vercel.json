{
  "crons": [
    {
      "path": "/api/cron/trial-notifications?secret=${CRON_SECRET}",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/renewal?secret=${CRON_SECRET}",
      "schedule": "30 12 * * *"
    },
    {
      "path": "/api/cron/winback?secret=${CRON_SECRET}",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/reconcile-payments?secret=${CRON_SECRET}",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/proxy-usage?secret=${CRON_SECRET}",
      "schedule": "*/5 * * * *"
    }
  ]
}
